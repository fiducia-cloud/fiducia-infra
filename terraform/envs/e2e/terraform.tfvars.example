# Copy to terraform.tfvars and fill in. Toggle the clouds you want.
# Credentials are NOT set here — use each provider's standard auth:
#   GCP:     gcloud auth application-default login   (or GOOGLE_APPLICATION_CREDENTIALS)
#   AWS:     AWS_PROFILE / AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
#   Azure:   az login
#   Hetzner: export HCLOUD_TOKEN=...

enable_gcp     = true
enable_aws     = true
enable_azure   = true
enable_hetzner = true

node_count = 3

# Required when enable_gcp = true:
gcp_project_id = "your-gcp-project-id"

# Required when enable_hetzner = true (contents of e.g. ~/.ssh/id_ed25519.pub):
hetzner_ssh_public_key = "ssh-ed25519 AAAA... you@host"

# Optional production-like hardening. Defaults preserve disposable e2e access.
# Replace the example CIDRs/subnets with real operator, VPC, edge, and mesh
# ranges before enabling.
gcp_deletion_protection     = false
gcp_enable_private_cluster  = false
gcp_enable_private_endpoint = false
gcp_master_ipv4_cidr_block  = "172.16.0.0/28"
gcp_authorized_api_cidrs    = ["203.0.113.10/32"]
gcp_enable_network_policy   = true

aws_subnet_ids              = [] # dedicated private subnet ids for hardened runs
aws_endpoint_public_access  = true
aws_endpoint_private_access = false
aws_authorized_api_cidrs    = ["203.0.113.10/32"]

azure_authorized_api_cidrs  = ["203.0.113.10/32"]
azure_enable_network_policy = true

hetzner_enable_firewall        = true
hetzner_firewall_allowed_cidrs = ["203.0.113.10/32"]
