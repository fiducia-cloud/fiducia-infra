# Template for the disposable Hetzner FSN1 emulation member. up.sh injects
# actual Kind control-plane addresses into its rendered output without changing
# this tracked file.
FIDUCIA_CLUSTER=hetzner-fsn1
FIDUCIA_CLUSTER_ID=fiducia-emulation-hetzner
FIDUCIA_SHARD_COUNT=16
FIDUCIA_REPLICATION_FACTOR=3
FIDUCIA_TARGET_NODES=3
FIDUCIA_SELF_ADDR=127.0.0.1:30080
FIDUCIA_PEERS=127.0.0.2:30090,127.0.0.3:30090
FIDUCIA_BRAIN_PEERS=http://127.0.0.2:30095,http://127.0.0.3:30095
FIDUCIA_RAFT_TICK_MS=50
FIDUCIA_RAFT_HEARTBEAT_MS=100
FIDUCIA_RAFT_ELECTION_MIN_MS=600
FIDUCIA_RAFT_ELECTION_JITTER_MS=600
FIDUCIA_RAFT_CHECK_QUORUM=on
FIDUCIA_AUTH_REQUIRED=true
