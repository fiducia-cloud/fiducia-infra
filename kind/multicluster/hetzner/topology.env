# fiducia-cluster ConfigMap inputs for the emulated "hetzner" cloud.
#
# FIDUCIA_PEERS / FIDUCIA_BRAIN_PEERS are PLACEHOLDERS — up.sh rewrites the two
# lines in place with the discovered <control-plane-container-ip>:NodePort of the
# OTHER two clusters (vultr, civo). Pods can't resolve Kind container DNS names, so
# cross-cluster peers are addressed by IP over the shared `kind` Docker network.
FIDUCIA_CLUSTER=hetzner
FIDUCIA_CLUSTER_ID=fiducia-emulation
FIDUCIA_SHARD_COUNT=16
FIDUCIA_REPLICATION_FACTOR=3
FIDUCIA_TARGET_NODES=3
FIDUCIA_PEERS=10.255.255.20:30090,10.255.255.30:30090
FIDUCIA_BRAIN_PEERS=10.255.255.20:30095,10.255.255.30:30095
# Prod cross-cloud Raft timing — the point of this tier is to validate these
# values under emulated WAN latency/partitions. Mirrors topology.toml [raft].
FIDUCIA_RAFT_TICK_MS=50
FIDUCIA_RAFT_HEARTBEAT_MS=100
FIDUCIA_RAFT_ELECTION_MIN_MS=600
FIDUCIA_RAFT_ELECTION_JITTER_MS=600
FIDUCIA_RAFT_CHECK_QUORUM=on
