# fiducia-cluster ConfigMap inputs for the emulated "civo" cloud.
# FIDUCIA_PEERS / FIDUCIA_BRAIN_PEERS are PLACEHOLDERS rewritten by up.sh with the
# discovered container IPs of the OTHER two clusters (hetzner, vultr). See
# ../hetzner/topology.env for the full explanation.
FIDUCIA_CLUSTER=civo
FIDUCIA_CLUSTER_ID=fiducia-emulation
FIDUCIA_SHARD_COUNT=16
FIDUCIA_REPLICATION_FACTOR=3
FIDUCIA_TARGET_NODES=3
FIDUCIA_PEERS=10.255.255.10:30090,10.255.255.20:30090
FIDUCIA_BRAIN_PEERS=10.255.255.10:30095,10.255.255.20:30095
FIDUCIA_RAFT_TICK_MS=50
FIDUCIA_RAFT_HEARTBEAT_MS=100
FIDUCIA_RAFT_ELECTION_MIN_MS=600
FIDUCIA_RAFT_ELECTION_JITTER_MS=600
FIDUCIA_RAFT_CHECK_QUORUM=on
