# kind (local) overlay — NOT generated by render.mjs (that tool targets the real
# clusters in ../../clusters). This runs a single 4-replica fiducia-node group on
# one kind cluster, with replicas spread one-per-zone by topologySpread.
#
# FIDUCIA_PEERS is the explicit in-cluster pod list (the StatefulSet's stable pod
# DNS); each node dedups itself. This is a single-cluster Raft group standing in
# for the cross-cloud group — good enough to exercise the coordination API.
FIDUCIA_CLUSTER=kind
FIDUCIA_CLUSTER_ID=fiducia-e2e
FIDUCIA_SHARD_COUNT=16
FIDUCIA_REPLICATION_FACTOR=3
FIDUCIA_TARGET_NODES=4
FIDUCIA_PEERS=fiducia-node-0.fiducia-node.fiducia.svc.cluster.local:9090,fiducia-node-1.fiducia-node.fiducia.svc.cluster.local:9090,fiducia-node-2.fiducia-node.fiducia.svc.cluster.local:9090,fiducia-node-3.fiducia-node.fiducia.svc.cluster.local:9090
FIDUCIA_BRAIN_PEERS=
# LAN timing is fine on a single local cluster (unlike the cross-cloud overlays).
FIDUCIA_RAFT_TICK_MS=50
FIDUCIA_RAFT_HEARTBEAT_MS=50
FIDUCIA_RAFT_ELECTION_MIN_MS=150
FIDUCIA_RAFT_ELECTION_JITTER_MS=150
FIDUCIA_RAFT_CHECK_QUORUM=on
